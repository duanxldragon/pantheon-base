{
  "dashboard": {
    "title": "Pantheon Base - API Overview",
    "tags": ["pantheon", "api", "http"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "HTTP Requests per Second (QPS)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(pantheon_http_requests_total[1m])) by (method)",
            "legendFormat": "{{method}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"label": "requests/sec", "format": "short"},
          {"format": "short"}
        ]
      },
      {
        "id": 2,
        "title": "HTTP Request Duration (P95)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(pantheon_http_request_duration_seconds_bucket[5m])) by (le, path))",
            "legendFormat": "{{path}} (P95)",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(pantheon_http_request_duration_seconds_bucket[5m])) by (le, path))",
            "legendFormat": "{{path}} (P99)",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"label": "seconds", "format": "s"},
          {"format": "short"}
        ],
        "alert": {
          "name": "High API Latency",
          "conditions": [
            {
              "evaluator": {"params": [0.5], "type": "gt"},
              "query": {"params": ["A", "5m", "now"]},
              "type": "query"
            }
          ],
          "frequency": "1m",
          "handler": 1,
          "message": "API P95 latency exceeds 500ms"
        }
      },
      {
        "id": 3,
        "title": "Error Rate (%)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "sum(rate(pantheon_http_requests_total{status=~\"5..\"}[1m])) / sum(rate(pantheon_http_requests_total[1m])) * 100",
            "legendFormat": "5xx Error Rate",
            "refId": "A"
          },
          {
            "expr": "sum(rate(pantheon_http_requests_total{status=~\"4..\"}[1m])) / sum(rate(pantheon_http_requests_total[1m])) * 100",
            "legendFormat": "4xx Error Rate",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"label": "percentage", "format": "percent"},
          {"format": "short"}
        ],
        "alert": {
          "name": "High Error Rate",
          "conditions": [
            {
              "evaluator": {"params": [5], "type": "gt"},
              "query": {"params": ["A", "5m", "now"]},
              "type": "query"
            }
          ],
          "frequency": "1m",
          "handler": 1,
          "message": "API error rate exceeds 5%"
        }
      },
      {
        "id": 4,
        "title": "Request Status Distribution",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "sum(increase(pantheon_http_requests_total[1h])) by (status)",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "title": "Top 10 Slowest Endpoints",
        "type": "table",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "topk(10, histogram_quantile(0.95, sum(rate(pantheon_http_request_duration_seconds_bucket[5m])) by (le, path, method)))",
            "format": "table",
            "refId": "A"
          }
        ]
      }
    ]
  }
}
