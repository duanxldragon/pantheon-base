# Pantheon Base
# 请勿提交此文件到版本控制系统
# 使用 .env.example 作为模板

# ============================================
# 应用配置
# ============================================
PANTHEON_ENV=production
PANTHEON_PORT=8080

# ============================================
# 数据库配置
# ============================================
MYSQL_ROOT_PASSWORD=change_this_strong_password_123!
PANTHEON_DSN=root:change_this_strong_password_123!@tcp(mysql:3306)/pantheon?charset=utf8mb4&parseTime=True&loc=UTC

# ============================================
# Redis 配置
# ============================================
REDIS_PASSWORD=change_this_redis_password_456!
PANTHEON_REDIS_ADDR=redis:6379
PANTHEON_REDIS_PASSWORD=change_this_redis_password_456!

# ============================================
# 监控配置
# ============================================
OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:4318

# Grafana
GRAFANA_ADMIN_PASSWORD=change_this_grafana_password_789!

# ============================================
# 安全配置
# ============================================
# CORS 允许的源（逗号分隔，生产环境必须配置）
PANTHEON_ALLOWED_ORIGINS=https://your-domain.com

# CSP 报告端点（可选）
# CSP_REPORT_URI=https://your-csp-report-endpoint.com

# ============================================
# JWT 密钥（生产环境必须修改）
# ============================================
# 使用以下命令生成随机密钥：
# openssl rand -base64 32

# 注意：这些密钥在 backend/pkg/common/security_config.go 中有默认值
# 生产环境必须通过环境变量覆盖

# ============================================
# 低代码模块代码生成平台配置
# ============================================
# 低代码生成器与动态模块注册门禁。
# 注意：生成器本身在生产环境不可用（仅低代码向导与已注册模块提供），
# 但动态模块注册/激活会通过运行时修改 generated 注册表，
# 因此生产环境必须显式禁用，避免被误开。
#
# 取值：true | false
# 默认：
#   - production（生产）：false（必须保持关闭）
#   - 其他环境（development/staging/qa）：true
PANTHEON_ENABLE_DYNAMIC_MODULES=true

# 低代码生成器写入源码/schema 的工作区根目录。
# 留空则由 scaffold.ResolveWorkspaceRoot 按 git 根自动推断（推荐）。
# 显式配置时必须是绝对路径且具备可写权限。
# PANTHEON_WORKSPACE_ROOT=/absolute/path/to/workspace

# 强制指定 Node.js 可执行文件路径（绝对路径）。
# 留空则沿用 PATH 中的 node。
# 仅在多版本 Node 共存或容器化部署时需要配置。
# PANTHEON_NODE_BIN=/usr/local/bin/node
