{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "predev": "npm run patch:arco-react19",
    "prebuild": "npm run patch:arco-react19 && npm run check:menu-contract && npm run check:i18n-hardcode && npm run check:i18n-generated-scope && npm run check:system-datetime-presentation && npm run check:shell-visual-contract && npm run check:system-page-admission && npm run check:smoke-web-base && npm run check:smoke-coverage-contract",
    "build": "tsc -b && vite build",
    "postinstall": "npm run patch:arco-react19",
    "patch:arco-react19": "node ./scripts/patch-arco-react19.mjs",
    "check:menu-contract": "node ./scripts/check-menu-contract.mjs",
    "check:i18n-hardcode": "node ./scripts/check-i18n-hardcode.mjs",
    "check:i18n-generated-scope": "node ./scripts/check-i18n-generated-scope.mjs",
    "check:system-datetime-presentation": "node ./scripts/check-system-datetime-presentation.mjs",
    "check:shell-visual-contract": "node ./scripts/check-shell-visual-contract.mjs",
    "check:system-page-admission": "node ./scripts/check-system-page-admission.mjs",
    "check:smoke-web-base": "node ./scripts/check-smoke-web-base.mjs",
    "check:smoke-coverage-contract": "node ./scripts/check-smoke-coverage-contract.mjs",
    "test:smoke:scripts": "node --test ./scripts/run-smoke-suite.test.mjs ./scripts/load-resource-module.test.mjs ./scripts/patch-arco-react19.test.mjs ./scripts/export-generated-module.test.mjs ./scripts/cleanup-generated-modules.test.mjs ./scripts/database-import-qa-setup.test.mjs",
    "test:generator:dashboard-widget": "node ./scripts/run-generator-dashboard-widget-test.mjs",
    "test:generator:quality": "node ./scripts/run-generator-quality-contract-test.mjs",
    "test:lowcode:smoke": "node ./scripts/run-lowcode-smoke.mjs",
    "test:generator:smoke": "npm run test:generator:dashboard-widget && npm run test:generator:quality && npm run test:lowcode:smoke && npm run check:menu-contract && npm run check:i18n-hardcode && npm run check:i18n-generated-scope",
    "audit:i18n-locales": "node ./scripts/audit-i18n-locales.mjs",
    "audit:i18n-runtime": "node ./scripts/report-system-i18n-audit.mjs",
    "cleanup:i18n-unused-placeholders": "node ./scripts/cleanup-unused-i18n-placeholders.mjs",
    "type-check": "tsc -b",
    "export:i18n-builtin-snapshot": "cd .. && node frontend/scripts/export-i18n-builtin-snapshot.mjs",
    "lint": "eslint .",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "audit": "npm audit --registry=https://registry.npmjs.org --audit-level=high",
    "preview": "vite preview",
    "test:smoke:platform": "npm run test:smoke:platform:contracts && npm run test:smoke:platform:surfaces && npm run test:smoke:platform:full",
    "test:smoke:platform:contracts": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --config playwright.config.ts -- tests/smoke/platform/shell-visual-contract.spec.ts tests/smoke/platform/pagination-contract.spec.ts --workers=1",
    "test:smoke:platform:surfaces": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --config playwright.config.ts -- tests/smoke/platform/platform-shell.spec.ts tests/smoke/platform/backoffice-ui-visual.spec.ts tests/smoke/platform/shell-top-panels.spec.ts tests/smoke/platform/system-layout-contract.spec.ts tests/smoke/platform/system-secondary-route-visual.spec.ts tests/smoke/platform/system-secondary-route-interaction.spec.ts tests/smoke/platform/system-secondary-route-failure.spec.ts tests/smoke/platform/system-secondary-route-permission.spec.ts --workers=1",
    "test:smoke:platform:shell:preserve": "set PANTHEON_SMOKE_PRESERVE_FIXTURES=1&& node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --config playwright.config.ts -- tests/smoke/platform/platform-shell.spec.ts --workers=1",
    "smoke:preserve:platform-shell": "npm run test:smoke:platform:shell:preserve",
    "test:smoke:platform:full": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5174 --config playwright.full-system.config.ts -- tests/smoke/platform/full-system-pages.spec.ts tests/smoke/platform/full-page-audit.spec.ts",
    "test:smoke:system": "npm run test:smoke:system:pages && npm run test:smoke:system:forms && npm run test:smoke:system:iam-authz && npm run test:smoke:system:governance && npm run test:smoke:system:api",
    "test:smoke:system:pages": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --cleanup-fixtures all --config playwright.config.ts -- tests/smoke/system/system-pages.spec.ts",
    "test:smoke:system:pages:preserve": "set PANTHEON_SMOKE_PRESERVE_FIXTURES=1&& npm run test:smoke:system:pages",
    "smoke:preserve:system-pages": "npm run test:smoke:system:pages:preserve",
    "test:smoke:system:forms": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --cleanup-fixtures all --config playwright.config.ts -- tests/smoke/system/system-form-state-matrix.spec.ts --workers=1",
    "test:smoke:system:iam-authz": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --cleanup-fixtures all --config playwright.config.ts -- tests/smoke/system/role-authorization.spec.ts",
    "test:smoke:system:governance": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --cleanup-fixtures all --config playwright.config.ts -- tests/smoke/system/governance/system-governance-action-matrix.spec.ts tests/smoke/system/governance/governance-insight-drawer.spec.ts tests/smoke/system/governance/permission-workbench-remediation.spec.ts tests/smoke/system/governance/permission-workbench-remediation-real.spec.ts tests/smoke/system/governance/module-governance.spec.ts tests/smoke/system/governance/cleanup-range-ui.spec.ts --workers=1",
    "test:smoke:system:api": "playwright test tests/smoke/system/api/system-import-export.spec.ts tests/smoke/system/api/system-batch-delete.spec.ts --config=playwright.api.config.ts",
    "test:smoke:business": "npm run test:smoke:business:generated && npm run test:smoke:business:database-import && npm run test:smoke:business:master-detail && npm run test:smoke:business:many-to-many && npm run test:smoke:business:auto-recycle",
    "test:smoke:business:generated": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --cleanup-fixtures all --config playwright.config.ts -- tests/smoke/business/generated/module-governance-real.spec.ts",
    "test:smoke:business:database-import": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5173 --cleanup-fixtures all --setup scripts/database-import-qa-setup.mjs --config playwright.config.ts -- tests/smoke/business/generated/module-governance-host-real.spec.ts",
    "test:smoke:business:master-detail": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5174 --cleanup-fixtures all --setup scripts/master-detail-qa-setup.mjs --config playwright.master-detail.config.ts -- tests/smoke/business/generated/module-master-detail-real.spec.ts",
    "test:smoke:business:many-to-many": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5174 --cleanup-fixtures all --setup scripts/many-to-many-qa-setup.mjs --config playwright.many-to-many.config.ts -- tests/smoke/business/generated/module-many-to-many-real.spec.ts",
    "test:smoke:business:auto-recycle": "node scripts/run-smoke-suite.mjs --host 127.0.0.1 --port 5174 --cleanup-fixtures all --proxy-target http://127.0.0.1:8080 --config playwright.auto-recycle.config.ts -- tests/smoke/business/generated/module-auto-recycle-real.spec.ts",
    "test:smoke:all": "npm run test:smoke:platform && npm run test:smoke:system && npm run test:smoke:business",
    "smoke:preserve": "npm run smoke:preserve:system-pages",
    "smoke:cleanup": "node scripts/cleanup-smoke-fixtures.mjs",
    "smoke:cleanup:iam": "node scripts/cleanup-smoke-fixtures.mjs --scope iam",
    "smoke:cleanup:org": "node scripts/cleanup-smoke-fixtures.mjs --scope org",
    "smoke:cleanup:config": "node scripts/cleanup-smoke-fixtures.mjs --scope config",
    "check:contrast": "node ./scripts/check-contrast.mjs",
    "check:important-budget": "node ./scripts/check-important-budget.mjs"
  },
  "dependencies": {
    "@arco-design/web-react": "2.66.16",
    "axios": "^1.18.1",
    "i18next": "26.3.6",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "17.0.9",
    "react-router-dom": "7.18.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/jszip": "^3.4.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jszip": "^3.10.1",
    "nyc": "^18.0.0",
    "prettier": "^3.9.5",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vite-plugin-istanbul": "^9.0.1"
  }
}
