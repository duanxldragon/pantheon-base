ight: 40px;\n  height: 40px;\n  padding: 0 14px !important;\n  border: 1px solid transparent;\n  border-radius: 12px;\n  background: color-mix(in srgb, var(--brand-primary) 3%, #ffffff);\n  color: var(--text-secondary);\n  font-weight: 500;\n  line-height: 40px;\n  transition: border-color 0.18s ease, background 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;\n}\n\n.app-shell__top-menu .arco-menu-item:hover,\n.app-shell__top-menu .arco-menu-pop-header:hover,\n.app-shell__top-menu .arco-menu-inline-header:hover {\n  border-color: color-mix(in srgb, var(--brand-primary) 16%, var(--panel-border));\n  color: var(--brand-primary);\n  background: color-mix(in srgb, var(--brand-primary) 7%, #ffffff) !important;\n}\n\n.app-shell__top-menu .arco-menu-selected,\n.app-shell__top-menu .arco-menu-pop-header.arco-menu-selected,\n.app-shell__top-menu .arco-menu-inline-header.arco-menu-selected {\n  border-color: color-mix(in srgb, var(--brand-primary) 18%, var(--panel-border));\n  color: var(--brand-primary) !important;\n  font-weight: 600;\n  background: color-mix(in srgb, var(--brand-primary) 8%, #ffffff) !important;\n  box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--brand-primary) 6%, transparent);\n}\n\n.app-shell__top-menu .arco-menu-selected::after,\n.app-shell__top-menu .arco-menu-pop-header.arco-menu-selected::after,\n.app-shell__top-menu .arco-menu-inline-header.arco-menu-selected::after {\n  left: 14px !important;\n  right: 14px !important;\n  bottom: 4px !important;\n  height: 3px !important;\n  border-radius: 999px;\n  background: var(--brand-primary) !important;\n}\n\n.app-shell__top-menu .arco-menu-icon {\n  color: inherit;\n}\n\n.app-shell__top-menu .arco-menu-pop {\n  margin-left: 0 !important;\n}\n\n.app-shell__top-menu-popup {\n  padding-top: 10px;\n}\n\n.app-shell__top-menu-popup .arco-menu {\n  min-width: 220px;\n  padding: 8px;\n  border: 1px solid color-mix(in srgb, var(--panel-border) 86%, transparent);\n  border-radius: 16px;\n  background: var(--