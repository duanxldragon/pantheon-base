-breadcrumb-item:last-child a {\n  color: var(--text-secondary);\n}\n\n.app-shell__tabs {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  min-height: 44px;\n  padding: 6px 28px 8px;\n  overflow-x: auto;\n  border-bottom: 1px solid var(--panel-border);\n  background: var(--panel-bg-solid);\n}\n\n.app-shell__tab {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  flex: 0 0 auto;\n  max-width: 180px;\n  height: 32px;\n  padding: 0 10px 0 12px;\n  border: 1px solid color-mix(in srgb, var(--panel-border) 82%, transparent);\n  border-radius: 10px;\n  background: var(--panel-bg-solid);\n  color: var(--text-secondary);\n  font: inherit;\n  font-size: 12px;\n  font-weight: 500;\n  line-height: 1;\n  cursor: pointer;\n  transition: background 0.18s ease, border-color 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;\n}\n\n.app-shell__tab:hover {\n  border-color: color-mix(in srgb, var(--brand-primary) 12%, var(--panel-border));\n  background: color-mix(in srgb, var(--brand-primary) 4%, #ffffff);\n  color: var(--text-primary);\n}\n\n.app-shell__tab--active {\n  border-color: color-mix(in srgb, var(--brand-primary) 16%, var(--panel-border));\n  background: color-mix(in srgb, var(--brand-primary) 8%, #ffffff);\n  color: var(--brand-primary);\n  box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--brand-primary) 6%, transparent);\n}\n\n.app-shell__tab--pinned {\n  border-style: solid;\n}\n\n.app-shell__tab--dragging {\n  opacity: 0.58;\n  box-shadow: none;\n}\n\n.app-shell__tab--drag-over {\n  border-color: color-mix(in srgb, var(--brand-primary) 24%, var(--panel-border));\n  background: color-mix(in srgb, var(--brand-primary) 12%, #ffffff);\n}\n\n.app-shell__tab-pin {\n  flex: 0 0 auto;\n  font-size: 12px;\n  color: color-mix(in srgb, var(--brand-primary) 62%, var(--text-tertiary));\n  transform: rotate(35deg);\n}\n\n.app-shell__tab-label {\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n\n.app-shell__tab-close {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  width: 18px;\n  height: 18px;\n  margin-right: -4px;\n  border-radius: 8px;\n  color: var(--text-tertiary);\n  transition: background 0.18s ease, color 0.18s ease;\n}\n\n.app-shell__tab-close:hover {\n  background: color-mix(in srgb, var(--brand-primary) 8%, #ffffff);\n  color: var(--brand-primary);\n}\n\n.app-shell__tab-menu {\n  min-width: 144px;\n  padding: 6px;\n  border: 1px solid color-mix(in srgb, var(--panel-border) 88%, transparent);\n  border-radius: 12px;\n  background: var(--panel-bg-solid);\n  box-shadow: var(--panel-shadow-soft);\n}\n\n.app-shell__tab-menu .arco-dropdown-menu-item {\n  border-radius: 8px;\n  font-size: 13px;\n}\n\n.app-shell__content {\n  padding: 24px 28px 0;\n  overflow: auto;\n  background: linear-gradient(180deg, #f7fbfb 0%, #f5faf8 100%);\n}\n\n.app-shell__content-inner {\n  min-height: calc(100vh - 160px);\n}\n\n.app-shell--horizontal .app-shell__content-inner {\n  min-height: calc(100vh - 220px);\n}\n\n.app-shell__footer {\n  padding: 16px 28px 24px;\n  background: transparent;\n  color: var(--text-tertiary);\n  text-align: left;\n}\n\n.app-shell__user-trigger .arco-avatar {\n  background: var(--brand-primary);\n}\n\n.app-shell__notice-panel {\n  width: 300px;\n  padding: 10px;\n  border: 1px solid color-mix(in srgb, var(--panel-border) 88%, transparent);\n  border-radius: 12px;\n  background: var(--panel-bg-solid);\n  box-shadow: var(--panel-shadow-soft);\n}\n\n.app-shell__notice-header {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n  margin-bottom: 10px;\n}\n\n.app-shell__notice-title {\n  color: var(--text-primary);\n  font-size: 14px;\n  font-weight: 600;\n}\n\n.app-shell__notice-subtitle {\n  color: var(--text-secondary);\n  font-size: 12px;\n  line-height: 1.5;\n}\n\n.app-shell__notice-empty {\n  padding: 10px 12px;\n  border: 1px dashed color-mix(in srgb, var(--brand-primary) 14%, var(--panel-border));\n  border-radius: 12px;\n  background: color-mix(in srgb, var(--brand-primary) 4%, #ffffff);\n  color: var(--text-secondary);\n  font-size: 12px;\n  line-height: 1.6;\n}\n\n.app-shell__notice-empty--compact {\n  margin-top: 0;\n}\n\n.app-shell__notice-stats {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: 6px;\n  margin-bottom: 10px;\n}\n\n.app-shell__notice-stat {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n  padding: 8px 10px;\n  border: 1px solid color-mix(in srgb, var(--panel-border) 88%, transparent);\n  border-radius: 12px;\n  background: color-mix(in srgb, var(--brand-primary) 4%, #ffffff);\n}\n\n.app-shell__notice-stat--danger {\n  border-color: color-mix(in srgb, var(--danger-soft) 82%, var(--panel-border));\n  background: color-mix(in srgb, var(--danger-soft) 42%, #ffffff);\n}\n\n.app-shell__notice-stat-label {\n  color: var(--text-secondary);\n  font-size: 11px;\n  line-height: 1.4;\n}\n\n.app-shell__notice-stat-value {\n  color: var(--text-primary);\n  font-size: 16px;\n  font-weight: 600;\n}\n\n.app-shell__notice-summary {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 8px;\n  margin-bottom: 10px;\n  padding: 8px 10px;\n  border-radius: 12px;\n  background: color-mix(in srgb, var(--brand-primary) 4%, #ffffff);\n}\n\n.app-shell__notice-summary-label {\n  color: var(--text-secondary);\n  font-size: 12px;\n}\n\n.app-shell__notice-summary-value {\n  color: var(--text-primary);\n  font-size: 12px;\n  font-weight: 600;\n  text-align: right;\n}\n\n.app-shell__notice-risk {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n  width: 100%;\n  padding: 9px 10px;\n  border: 1px solid color-mix(in srgb, var(--panel-border) 88%, transparent);\n  border-radius: 12px;\n  background: color-mix(in srgb, var(--brand-primary) 4%, #ffffff);\n  color: inherit;\n  text-align: left;\n  transition: border-color 0.18s ease, background 0.18s ease;\n}\n\n.app-shell__notice-risk + .app-shell__notice-risk {\n  margin-top: 6px;\n}\n\n.app-shell__notice-risk:hover {\n  border-color: color-mix(in srgb, var(--brand-primary) 12%, var(--panel-border));\n  background: color-mix(in srgb, var(--brand-primary) 6%, #ffffff);\n}\n\n.app-shell__notice-risk--danger {\n  border-color: color-mix(in srgb, var(--danger-soft) 88%, var(--panel-border));\n  background: color-mix(in srgb, var(--danger-soft) 42%, #ffffff);\n}\n\n.app-shell__notice-risk--warning {\n  border-color: color-mix(in srgb, var(--status-warning-soft) 88%, var(--panel-border));\n  background: color-mix(in srgb, var(--status-warning-soft) 42%, #ffffff);\n}\n\n.app-shell__notice-risk-copy {\n  display: inline-flex;\n  flex-direction: column;\n  gap: 2px;\n  min-width: 0;\n}\n\n.app-shell__notice-risk-title {\n  color: var(--text-primary);\n  font-size: 13px;\n  font-weight: 600;\n}\n\n.app-shell__notice-risk-desc {\n  color: var(--text-secondary);\n  font-size: 12px;\n  line-height: 1.5;\n}\n\n.app-shell__notice-risk-value {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  min-width: 28px;\n  height: 28px;\n  padding-inline: 8px;\n  border-radius: 999px;\n  background: rgba(255, 255, 255, 0.82);\n  color: var(--text-primary);\n  font-size: 13px;\n  font-weight: 700;\n  flex-shrink: 0;\n}\n\n.app-shell__notice-list {\n  margin-top: 10px;\n}\n\n.app-shell__notice-section {\n  margin-bottom: 8px;\n  color: var(--text-tertiary);\n  font-size: 12px;\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.04em;\n}\n\n.app-shell__notice-item {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  width: 100%;\n  padding: 8px 10px;\n  border: 1px solid transparent;\n  border-radius: 12px;\n  background: transparent;\n  color: inherit;\n  text-align: left;\n  transition: border-color 0.18s ease, background 0.18s ease;\n}\n\n.app-shell__notice-item + .app-shell__notice-item {\n  margin-top: 4px;\n}\n\n.app-shell__notice-item:hover {\n  border-color: color-mix(in srgb, var(--brand-primary) 12%, var(--panel-border));\n  background: color-mix(in srgb, var(--brand-primary) 4%, #ffffff);\n}\n\n.app-shell__notice-item-icon {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  width: 28px;\n  height: 28px;\n  border-radius: 9px;\n  background: color-mix(in srgb, var(--brand-primary) 8%, #ffffff);\n  color: var(--brand-primary);\n  flex-shrink: 0;\n}\n\n.app-shell__notice-item-copy {\n  display: inline-flex;\n  flex-direction: column;\n  gap: 2px;\n  min-width: 0;\n}\n\n.app-shell__notice-item-title {\n  color: var(--text-primary);\n  font-size: 13px;\n  font-weight: 600;\n}\n\n.app-shell__notice-item-desc {\n  color: var(--text-secondary);\n  font-size: 12px;\n  line-height: 1.5;\n}\n\n.app-shell__notice-log {\n  display: flex;\n  align-items: flex-start;\n  gap: 10px;\n  padding: 10px 0;\n}\n\n.app-shell__notice-log + .app-shell__notice-log {\n  border-top: 1px solid color-mix(in srgb, var(--panel-border) 82%, transparent);\n}\n\n.app-shell__notice-log-dot {\n  width: 8px;\n  height: 8px;\n  margin-top: 7px;\n  border-radius: 50%;\n  flex-shrink: 0;\n  background: var(--text-tertiary);\n}\n\n.app-shell__notice-log-dot--success {\n  background: #00B42A;\n}\n\n.app-shell__notice-log-dot--danger {\n  background: #F53F3F;\n}\n\n.app-shell__notice-log-copy {\n  display: inline-flex;\n  flex: 1;\n  min-width: 0;\n  flex-direction: column;\n  gap: 2px;\n}\n\n.app-shell__notice-log-title {\n  color: var(--text-primary);\n  font-size: 13px;\n  font-weight: 600;\n}\n\n.app-shell__notice-log-desc {\n  color: var(--text-secondary);\n  font-size: 12px;\n  line-height: 1.5;\n}\n\n.app-shell__notice-log-time {\n  color: var(--text-tertiary);\n  font-size: 11px;\n  line-height: 1.5;\n  text-align: right;\n}\n\n.app-shell__notice-badge {\n  position: absolute;\n  top: 3px;\n  right: 3px;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  min-width: 16px;\n  height: 16px;\n  padding-inline: 4px;\n  border-radius: 999px;\n  background: #F53F3F;\n  color: #fff;\n  font-size: 10px;\n  font-weight: 700;\n  line-height: 1;\n}\n\n.app-command__input {\n  margin-bottom: 12px;\n}\n\n.app-command__results {\n  max-height: 360px;\n  overflow: auto;\n}\n\n.app-command__section {\n  margin: 12px 0 6px;\n  color: var(--text-tertiary);\n  font-size: 12px;\n  font-weight: 600;\n  letter-spacing: 0.04em;\n  text-transform: uppercase;\n}\n\n.app-command__section:first-child {\n  margin-top: 0;\n}\n\n.app-command__item {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  width: 100%;\n  padding: 8px 10px;\n  border: 1px solid transparent;\n  border-radius: 10px;\n  background: transparent;\n  color: inherit;\n  text-align: left;\n  transition: border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;\n}\n\n.app-command__item:hover {\n  border-color: color-mix(in srgb, var(--brand-primary) 12%, var(--panel-border));\n  background: color-mix(in srgb, var(--brand-primary) 4%, #ffffff);\n}\n\n.app-command__item + .app-command__item {\n  margin-top: 4px;\n}\n\n.app-command__item-icon {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  width: 28px;\n  height: 28px;\n  border-radius: 9px;\n  background: color-mix(in srgb, var(--brand-primary) 8%, #ffffff);\n  color: var(--brand-primary);\n  flex-shrink: 0;\n}\n\n.app-command__item-copy {\n  display: inline-flex;\n  flex-direction: column;\n  gap: 2px;\n  min-width: 0;\n}\n\n.app-command__item-title {\n  color: var(--text-primary);\n  font-size: 13px;\n  font-weight: 600;\n}\n\n.app-command__item-subtitle {\n  color: var(--text-secondary);\n  font-size: 12px;\n  line-height: 1.5;\n}\n\n@media (max-width: 1200px) {\n  .app-shell__header {\n    padding-inline: 20px;\n  }\n\n  .app-shell__header-actions {\n    flex-basis: 360px;\n  }\n\n  .app-shell__search-trigger {\n    min-width: 220px;\n  }\n\n  .app-shell__top-nav {\n    padding-inline: 16px;\n  }\n}\n\n@media (max-width: 960p