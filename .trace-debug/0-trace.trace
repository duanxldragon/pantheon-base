 {\n  color: var(--text-primary);\n}\n\n.arco-tabs-tab-active,\n.arco-tabs-tab-active:hover {\n  color: var(--brand-primary);\n}\n\n.arco-tabs-type-rounded .arco-tabs-tab {\n  border-radius: var(--radius-pill);\n}\n\n.arco-tabs-type-rounded .arco-tabs-tab-active {\n  background: color-mix(in srgb, var(--brand-primary) 10%, #fff);\n  box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--brand-primary) 14%, transparent);\n}\n\n.arco-descriptions {\n  border-radius: var(--radius-md);\n}\n\n.arco-descriptions-item-label {\n  color: var(--text-tertiary);\n  font-weight: 500;\n}\n\n.arco-descriptions-item-value {\n  color: var(--text-primary);\n}\n\n.arco-descriptions-table {\n  border-radius: var(--radius-md);\n  overflow: hidden;\n}\n\n.arco-descriptions-bordered .arco-descriptions-item-label,\n.arco-descriptions-bordered .arco-descriptions-item-value {\n  border-color: var(--panel-border) !important;\n}\n\n.arco-tag {\n  min-height: 24px;\n  padding-inline: 10px;\n  border-radius: var(--radius-pill);\n  font-weight: 500;\n  line-height: 22px;\n  border-color: color-mix(in srgb, var(--panel-border) 92%, transparent);\n}\n\n.arco-empty-icon,\n.arco-result-icon {\n  color: var(--brand-primary);\n}\n\n.page-empty .page-empty__inner {\n  width: min(100%, 420px);\n  padding: 30px 22px;\n  border: 1px dashed color-mix(in srgb, var(--brand-primary) 14%, var(--panel-border));\n  border-radius: var(--radius-md);\n  background: linear-gradient(180deg, color-mix(in srgb, var(--brand-primary) 2%, #ffffff) 0%, #ffffff 100%);\n}\n\n.page-empty .arco-empty-image {\n  margin-bottom: 12px;\n}\n\n.page-empty .arco-empty-description {\n  color: var(--text-secondary);\n  line-height: 1.7;\n}\n\n.page-result {\n  width: min(100%, 720px);\n  margin: 0 auto;\n  border: 1px solid var(--panel-border);\n  border-radius: var(--radius-md);\n  background: linear-gradient(180deg, color-mix(in srgb, var(--brand-primary) 2%, #ffffff) 0%, #ffffff 100%);\n  box-shadow: var(--panel-shadow-soft);\n}\n\n.page-result .arco-result {\n  padding-top: 36px;\n  padding-bottom: 32px;\n}\n\n.page-result .arco-result-title {\n  color: var(--text-primary);\n  font-size: 18px;\n  font-weight: 600;\n}\n\n.page-result .arco-result-subtitle {\n  color: var(--text-secondary);\n  line-height: 1.7;\n}\n\n.page-result .arco-result-extra {\n  margin-top: 24px;\n}\n\n.page-result .arco-result-extra .arco-btn {\n  min-width: 96px;\n}\n\n.page-panel,\n.filter-panel {\n  border: 1px solid var(--panel-border);\n  border-radius: var(--radius-md);\n  background: var(--panel-bg-solid);\n  box-shadow: var(--panel-shadow-soft);\n}\n\n.app-table .arco-table-td,\n.app-table .arco-table-th {\n  padding-top: 12px;\n  padding-bottom: 12px;\n  line-height: 1.55;\n}\n\n.app-table {\n  font-variant-numeric: tabular-nums;\n}\n\n.app-table .arco-table-th {\n  letter-spacing: 0.01em;\n  white-space: nowrap;\n}\n\n.app-table .arco-table-container {\n  overflow: hidden;\n  border-radius: var(--radius-md);\n  background: var(--panel-bg-solid);\n}\n\n.app-table .arco-table-th:first-child,\n.app-table .arco-table-td:first-child {\n  padding-left: 16px;\n}\n\n.app-table .arco-table-th:last-child,\n.app-table .arco-table-td:last-child {\n  padding-right: 16px;\n}\n\n.app-table .arco-table-td {\n  color: var(--text-primary);\n  vertical-align: middle;\n  overflow-wrap: anywhere;\n}\n\n.app-table .arco-table-tbody .arco-table-tr:nth-child(even) .arco-table-td {\n  background: color-mix(in srgb, var(--brand-primary) 1.5%, #fff);\n}\n\n.app-table .arco-table-cell .arco-space {\n  flex-wrap: wrap;\n  row-gap: 6px;\n}\n\n.app-table .arco-table-cell .arco-btn,\n.app-table .arco-table-cell .arco-tag {\n  white-space: nowrap;\n}\n\n.app-table .arco-table-pagination {\n  padding: 18px 16px 4px;\n}\n\n.app-table .arco-pagination-item,\n.app-table .arco-pagination-item-link {\n  border-radius: 10px;\n}\n\n.arco-pagination {\n  color: var(--text-secondary);\n}\n\n.arco-pagination-item,\n.arco-pagination-item-prev,\n.arco-pagination-item-next,\n.arco-pagination-item-jumper {\n  border-radius: 10px;\n  transition: all 0.2s ease;\n}\n\n.arco-pagination-item:hover,\n.arco-pagination-item-prev:hover,\n.arco-pagination-item-next:hover {\n  color: var(--brand-primary);\n}\n\n.arco-pagination-item-active {\n  background: color-mix(in srgb, var(--brand-primary) 12%, #fff);\n  color: var(--brand-primary);\n  box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--brand-primary) 16%, transparent);\n}\n\n.arco-pagination-item-jumper input {\n  border-radius: 10px;\n}\n\n.app-table .arco-btn-size-small {\n  border-radius: 10px;\n}\n\n@media (max-width: 1200px) {\n  .page-header {\n    flex-direction: column;\n    align-items: stretch;\n  }\n\n  .system-page-kpi-grid,\n  .system-page-main-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .system-page-hero__top {\n    flex-direction: column;\n  }\n}\n\n@media (max-width: 768px) {\n  .system-page-hero .arco-card-body {\n    padding: 18px;\n  }\n\n  .system-page-hero__title {\n    font-size: 22px !important;\n  }\n\n  .system-page-kpi {\n    padding: 14px 16px;\n  }\n}\n"],["STYLE",{},".app-shell {\n  min-height: 100vh;\n  background: transparent;\n}\n\n.app-shell--horizontal {\n  flex-direction: column;\n}\n\n.app-shell__sider {\n  background:\n    linear-gradient(180deg, color-mix(in srgb, var(--brand-primary) 4%, #f8fbff) 0%, #f7fafc 100%);\n  border-right: 1px solid var(--panel-border);\n  box-shadow: none;\n}\n\n.app-shell__brand {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  min-height: 72px;\n  margin: 16px 16px 14px;\n  padding: 14px 14px 14px 12px;\n  border: 1px solid color-mix(in srgb, var(--brand-primary) 10%, var(--panel-border));\n  border-radius: var(--radius-md);\n  background: rgba(255, 255, 255, 0.84);\n}\n\n.app-shell__brand--collapsed {\n  justify-content: center;\n  padding: 14px 0;\n}\n\n.app-shell__brand-mark {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  width: 36px;\n  height: 36px;\n  border-radius: var(--radius-sm);\n  border: 1px solid color-mix(in srgb, var(--brand-primary) 18%, var(--panel-border));\n  background: color-mix(in srgb, var(--brand-primary) 8%, #ffffff);\n  color: var(--brand-primary);\n  font-size: 18px;\n  font-weight: 700;\n  box-shadow: none;\n  overflow: hidden;\n}\n\n.app-shell__brand-mark img,\n.app-shell__header-brand-mark img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n}\n\n.app-shell__brand-text {\n  display: flex;\n  flex-direction: column;\n  min-width: 0;\n}\n\n.app-shell__brand-title {\n  color: var(--text-primary);\n  font-size: 15px;\n  font-weight: 600;\n  line-height: 1.3;\n}\n\n.app-shell__brand-subtitle {\n  color: var(--text-tertiary);\n  font-size: 12px;\n  line-height: 1.4;\n}\n\n.app-shell__menu-loading {\n  display: block;\n  width: 100%;\n}\n\n.app-shell__menu {\n  padding: 0 10px 16px;\n  background: transparent;\n  border-inline-end: none !important;\n}\n\n.app-shell__menu .arco-menu-inner {\n  padding: 0;\n}\n\n.app-shell__menu-entry {\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  width: 100%;\n  min-width: 0;\n}\n\n.app-shell__menu-entry-copy {\n  display: inline-flex;\n  align-items: center;\n  min-width: 0;\n  flex: 1;\n}\n\n.app-shell__menu-entry-label {\n  min-width: 0;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n\n.app-shell__menu-entry-icon {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  flex-shrink: 0;\n  text-align: center;\n  transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease, transform 0.18s ease;\n}\n\n.app-shell__menu-entry-icon .arco-icon {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 100%;\n  height: 100%;\n  font-size: 16px;\n  line-height: 1;\n  margin-right: 0 !important;\n}\n\n.app-shell__menu-entry--level-0 {\n  gap: 10px;\n}\n\n.app-shell__menu-entry--level-1,\n.app-shell__menu-entry--level-2 {\n  gap: 10px;\n}\n\n.app-shell__menu-entry-icon--level-0 {\n  width: 28px;\n  height: 28px;\n  border: none;\n  border-radius: 8px;\n  background: transparent;\n  color: color-mix(in srgb, var(--brand-primary) 56%, var(--text-secondary));\n  box-shadow: none;\n}\n\n.app-shell__menu-entry-icon--level-1,\n.app-shell__menu-entry-icon--level-2 {\n  width: 22px;\n  height: 22px;\n  border: none;\n  border-radius: 7px;\n  background: transparent;\n  color: color-mix(in srgb, var(--brand-primary) 44%, var(--text-tertiary));\n  box-shadow: none;\n}\n\n.app-shell__menu-entry-icon--level-0 .arco-icon {\n  font-size: 15px;\n}\n\n.app-shell__menu-entry-icon--level-1 .arco-icon,\n.app-shell__menu-entry-icon--level-2 .arco-icon {\n  font-size: 13px;\n}\n\n.app-shell__menu .arco-menu-inline-header,\n.app-shell__menu .arco-menu-item {\n  position: relative;\n  min-height: 42px;\n  border-radius: 10px;\n  margin-bottom: 2px;\n  overflow: hidden;\n  transition: background 0.18s ease, box-shadow 0.18s ease, color 0.18s ease;\n}\n\n.app-shell__menu > .arco-menu-inner > .arco-menu-item,\n.app-shell__menu > .arco-menu-inner > .arco-menu-sub > .arco-menu-inline-header {\n  padding: 0 12px 0 14px !important;\n}\n\n.app-shell__menu .arco-menu-inline-header::before,\n.app-shell__menu .arco-menu-item::before {\n  content: '';\n  position: absolute;\n  top: 7px;\n  bottom: 7px;\n  left: 6px;\n  width: 3px;\n  border-radius: var(--radius-pill);\n  background: transparent;\n  opacity: 0;\n  transform: scaleY(0.55);\n  transition: opacity 0.18s ease, transform 0.18s ease, background 0.18s ease;\n}\n\n.app-shell__menu .arco-menu-item,\n.app-shell__menu .arco-menu-inline-header,\n.app-shell__menu .arco-menu-icon {\n  color: var(--text-secondary);\n}\n\n.app-shell__menu .arco-menu-item-inner,\n.app-shell__menu .arco-menu-inline-header .arco-menu-item-inner,\n.app-shell__menu .arco-menu-inline-header-title {\n  letter-spacing: 0.01em;\n  font-weight: 500;\n}\n\n.app-shell__menu .arco-menu-item,\n.app-shell__menu .arco-menu-inline-header {\n  background: transparent;\n}\n\n.app-shell__menu > .arco-menu-inner > .arco-menu-sub > .arco-menu-inline-content {\n  margin: 0 0 8px;\n}\n\n.app-shell__menu > .arco-menu-inner > .arco-menu-sub > .arco-menu-inline-content > .arco-menu-inner {\n  margin-left: 16px;\n  padding: 6px 0 6px 14px;\n  border-left: 1px solid color-mix(in srgb, var(--brand-primary) 12%, var(--panel-border));\n  background: transparent;\n}\n\n.app-shell__menu .arco-menu-inline-content .arco-menu-item {\n  min-height: 38px;\n  margin-bottom: 2px;\n  padding: 0 12px 0 14px !important;\n  background: transparent;\n}\n\n.app-shell__menu .arco-menu-inline-content .arco-menu-item .arco-menu-item-inner {\n  font-size: 13px;\n  font-weight: 500;\n  display: flex;\n  align-items: center;\n  min-height: 38px;\n}\n\n.app-shell__menu .arco-menu-inline-content .arco-menu-item::before {\n  left: 12px;\n  width: 2px;\n}\n\n.app-shell__menu .arco-menu-inline-content .app-shell__menu-entry {\n  align-items: center;\n}\n\n.app-shell__menu .arco-menu-inline-content .app-shell__menu-entry-copy {\n  min-height: 30px;\n  align-items: center;\n}\n\n.app-shell__menu .arco-menu-open > .arco-menu-inline-header {\n  background: color-mix(in srgb, var(--brand-primary) 5%, rgba(255,255,255,0.84)) !important;\n  color: var(--text-primary);\n}\n\n.app-shell__menu .arco-menu-open > .arco-menu-inline-header .arco-menu-item-inner,\n.app-shell__menu .arco-menu-open > .arco-menu-inline-header .arco-menu-inline-header-title {\n  font-weight: 600;\n}\n\n.app-shell__menu .arco-menu-open > .arco-menu-inline-header .arco-menu-icon,\n.app-shell__menu .arco-menu-open > .arco-menu-inline-header .arco-menu-icon-suffix .arco-icon {\n  color: var(--brand-primary) !important;\n}\n\n.app-shell__menu .arco-menu-open > .arco-menu-inline-header .app-shell__menu-entry-icon--level-0 {\n  background: color-mix(in srgb, var(--brand-primary) 10%, #ffffff);\n  color: var(--brand-primary);\n}\n\n.app-shell__menu .arco-menu-item:hover,\n.app-shell__menu .arco-menu-inline-header:hover {\n  background: color-mix(in srgb, var(--brand-primary) 4%, rgba(255,255,255,0.84)) !important;\n  color: var(--text-primary);\n  box-shadow: none;\n}\n\n.app-shell__menu .arco-menu-item:hover .app-shell__menu-entry-icon--level-0,\n.app-shell__menu .arco-menu-inline-header:hover .app-shell__menu-entry-icon--level-0 {\n  background: color-mix(in srgb, var(--brand-primary) 8%, #ffffff);\n  color: var(--brand-primary);\n}\n\n.app-shell__menu .arco-menu-item:hover .app-shell__menu-entry-icon--level-1,\n.app-shell__menu .arco-menu-item:hover .app-shell__menu-entry-icon--level-2,\n.app-shell__menu .arco-menu-inline-header:hover .app-shell__menu-entry-icon--level-1,\n.app-shell__menu .arco-menu-inline-header:hover .app-shell__menu-entry-icon--level-2 {\n  background: color-mix(in srgb, var(--brand-primary) 6%, #ffffff);\n  color: var(--brand-primary);\n}\n\n.app-shell__menu .arco-menu-selected,\n.app-shell__menu .arco-menu-inline-header.arco-menu-selected {\n  background: color-mix(in srgb, var(--brand-primary) 10%, rgba(255,255,255,0.92)) !important;\n  box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--brand-primary) 10%, transparent);\n}\n\n.app-shell__menu .arco-menu-selected,\n.app-shell__menu .arco-menu-selected .arco-menu-icon {\n  color: var(--brand-primary) !important;\n}\n\n.app-shell__menu .arco-menu-selected::before,\n.app-shell__menu .arco-menu-inline-header.arco-menu-selected::before {\n  opacity: 1;\n  transform: scaleY(1);\n  background: var(--brand-primary);\n}\n\n.app-shell__menu .arco-menu-selected .arco-menu-icon,\n.app-shell__menu .arco-menu-inline-header.arco-menu-selected .arco-menu-icon {\n  color: var(--brand-primary) !important;\n}\n\n.app-shell__menu .arco-menu-selected .app-shell__menu-entry-icon--level-0,\n.app-shell__menu .arco-menu-inline-header.arco-menu-selected .app-shell__menu-entry-icon--level-0 {\n  background: color-mix(in srgb, var(--brand-primary) 12%, #ffffff);\n  color: var(--brand-primary);\n  transform: none;\n}\n\n.app-shell__menu .arco-menu-selected .app-shell__menu-entry-icon--level-1,\n.app-shell__menu .arco-menu-selected .app-shell__menu-entry-icon--level-2,\n.app-shell__menu .arco-menu-inline-header.arco-menu-selected .app-shell__menu-entry-icon--level-1,\n.app-shell__menu .arco-menu-inline-header.arco-menu-selected .app-shell__menu-entry-icon--level-2 {\n  background: color-mix(in srgb, var(--brand-primary) 8%, #ffffff);\n  color: var(--brand-primary);\n}\n\n.app-shell__menu .arco-menu-selected .arco-menu-item-inner,\n.app-shell__menu .arco-menu-inline-header.arco-menu-selected .arco-menu-item-inner,\n.app-shell__menu .arco-menu-inline-header.arco-menu-selected .arco-menu-inline-header-title {\n  font-weight: 600;\n  letter-spacing: 0;\n}\n\n.app-shell__menu > .arco-menu-inner > .arco-menu-item > .arco-menu-item-inner,\n.app-shell__menu > .arco-menu-inner > .arco-menu-sub > .arco-menu-inline-header .arco-menu-item-inner,\n.app-shell__menu > .arco-menu-inner > .arco-menu-sub > .arco-menu-inline-header-title {\n  font-size: 14px;\n}\n\n.app-shell__menu > .arco-menu-inner > .arco-menu-sub > .arco-menu-inline-header .app-shell__menu-entry-label,\n.app-shell__menu > .arco-menu-inner > .arco-menu-item > .arco-menu-item-inner .app-shell__menu-entry-label {\n  font-size: 14px;\n}\n\n.app-shell__menu .arco-menu-inline-content .app-shell__menu-entry-label {\n  font-size: 14px;\n}\n\n.app-shell__menu .arco-menu-icon {\n  margin-right: 0 !important;\n}\n\n.app-shell__menu .arco-menu-icon-suffix {\n  color: var(--text-tertiary);\n}\n\n.app-shell__sider.arco-layout-sider-collapsed .app-shell__menu {\n  padding-inline: 10px;\n}\n\n.app-shell__sider.arco-layout-sider-collapsed .app-shell__menu-entry {\n  justify-content: center;\n}\n\n.app-shell__sider.arco-layout-sider-collapsed .app-shell__menu-entry-copy {\n  display: none;\n}\n\n.app-shell__sider.arco-layout-sider-collapsed .app-shell__menu-entry-icon--level-0,\n.app-shell__sider.arco-layout-